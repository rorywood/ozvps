# Ensure LF line endings for all text files
* text=auto eol=lf

# Explicitly set line endings for specific file types
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Windows batch files should keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
