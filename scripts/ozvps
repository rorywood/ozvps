    echo -e "${CYAN}в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї${NC}"
    echo ""
}

# ============================================================================
# Menu Actions
# ============================================================================

# 1. Application Status
action_app_status() {
    echo ""
    echo -e "${BOLD}Application Status${NC}"
    echo -e "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    pm2 describe "$SERVICE_NAME" 2>/dev/null || echo "Application not running"
    echo ""
    read -p "Press Enter to continue..." < /dev/tty
}

# 2. Database Status
action_db_status() {
    echo ""
    echo -e "${BOLD}Database Status${NC}"
    echo -e "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"

    if [[ -f "$INSTALL_DIR/.env" ]]; then
        local db_url=$(grep "^DATABASE_URL=" "$INSTALL_DIR/.env" | cut -d'=' -f2-)
        local db_name=$(parse_db_url "$db_url" "dbname")
        local db_host=$(parse_db_url "$db_url" "host")
        local db_user=$(parse_db_url "$db_url" "user")

        echo -e "  Database: ${BOLD}${db_name:-unknown}${NC}"
        echo -e "  Host:     ${BOLD}${db_host:-unknown}${NC}"
        echo -e "  User:     ${BOLD}${db_user:-unknown}${NC}"
        echo ""

        # Try to get table count and size
        if command -v psql &>/dev/null && [[ "$db_host" == "localhost" || "$db_host" == "127.0.0.1" ]]; then
            echo -e "  ${DIM}Checking database...${NC}"

            # Count tables
            local table_count=$(sudo -u postgres psql -d "$db_name" -t -c "SELECT count(*) FROM information_schema.tables WHERE table_schema = 'public';" 2>/dev/null | tr -d ' ')

            if [[ -n "$table_count" && "$table_count" != "" ]]; then
                echo -e "  Tables:   ${BOLD}$table_count${NC}"

                # Get database size
                local db_size=$(sudo -u postgres psql -d "$db_name" -t -c "SELECT pg_size_pretty(pg_database_size('$db_name'));" 2>/dev/null | tr -d ' ')
                echo -e "  Size:     ${BOLD}$db_size${NC}"
                echo -e "  Status:   ${GREEN}вњ“${NC} Connected"
            else
                # Connection test
                if sudo -u postgres psql -d "$db_name" -c "SELECT 1" &>/dev/null; then
                    echo -e "  Status:   ${GREEN}вњ“${NC} Connected"
                else
                    echo -e "  Status:   ${RED}вњ—${NC} Connection failed"
                fi
            fi
        else
            echo -e "  ${DIM}(psql not available or remote database)${NC}"
        fi
    else
        error ".env file not found"
    fi

    echo ""
    read -p "Press Enter to continue..." < /dev/tty
}

# 3. View Live Logs
action_live_logs() {
    echo ""
    echo -e "${BOLD}Live Logs${NC} ${DIM}(Ctrl+C to exit)${NC}"
    echo -e "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    pm2 logs "$SERVICE_NAME" --lines 50
}

# 4. System Resources
action_system_resources() {
    echo ""
    echo -e "${BOLD}System Resources${NC}"
    echo -e "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    echo ""

    # CPU
    local cpu_usage=$(top -bn1 | grep "Cpu(s)" | awk '{print $2}' | cut -d'%' -f1 2>/dev/null || echo "N/A")
    echo -e "  CPU Usage:    ${BOLD}${cpu_usage}%${NC}"

    # Memory
    local mem_info=$(free -h 2>/dev/null | grep Mem)
    local mem_total=$(echo "$mem_info" | awk '{print $2}')
    local mem_used=$(echo "$mem_info" | awk '{print $3}')
    echo -e "  Memory:       ${BOLD}${mem_used}${NC} / ${mem_total}"

    # Disk
    local disk_info=$(df -h / 2>/dev/null | tail -1)
    local disk_used=$(echo "$disk_info" | awk '{print $3}')
    local disk_total=$(echo "$disk_info" | awk '{print $2}')
    local disk_pct=$(echo "$disk_info" | awk '{print $5}')
    echo -e "  Disk (root):  ${BOLD}${disk_used}${NC} / ${disk_total} (${disk_pct})"

    # App memory
    local app_mem=$(pm2 jlist 2>/dev/null | grep -o '"name":"'$SERVICE_NAME'"[^}]*"memory":[0-9]*' | grep -o '"memory":[0-9]*' | cut -d':' -f2)
    if [[ -n "$app_mem" ]]; then
        local app_mem_mb=$((app_mem / 1024 / 1024))
        echo -e "  App Memory:   ${BOLD}${app_mem_mb}MB${NC}"
    fi

    echo ""
    read -p "Press Enter to continue..." < /dev/tty
}

