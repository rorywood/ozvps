#!/usr/bin/env bash
set -e

# ============================================================================
#  OzVPS Control Panel
#  Version: 4.0.1
#
#  Usage:
#    ozvps              # Opens kiosk menu
#    ozvps --update     # Direct update (no menu)
#    ozvps --status     # Show status dashboard
#    ozvps --help       # Show help
# ============================================================================

VERSION="4.0.1"
INSTALL_DIR="/opt/ozvps-panel"
SERVICE_NAME="ozvps-panel"
GITHUB_REPO="rorywood/ozvps"
BACKUP_DIR="/opt/ozvps-backups"

# ============================================================================
# Colors and Styling
# ============================================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# Status indicators
RUNNING="${GREEN}в—Џ${NC}"
STOPPED="${RED}в—Џ${NC}"
WARNING="${YELLOW}в—Џ${NC}"

# ============================================================================
# Self-Update Function (runs silently at startup)
# ============================================================================
self_update() {
    local SELF_PATH="$1"
    shift
    local SCRIPT_ARGS=("$@")

    # Get branch from installation (use same logic as get_branch)
    local BRANCH="main"
    if [[ -f "$INSTALL_DIR/.ozvps-branch" ]]; then
        BRANCH=$(head -1 "$INSTALL_DIR/.ozvps-branch" 2>/dev/null | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [[ -z "$BRANCH" ]] && BRANCH="main"
    fi

    local TEMP_SCRIPT=$(mktemp)

    # Get latest commit SHA using refs API (more reliable)
    local LATEST_SHA=""
    local REF_RESPONSE=$(curl -fsSL "https://api.github.com/repos/${GITHUB_REPO}/git/ref/heads/${BRANCH}" 2>/dev/null || true)
    if [[ -n "$REF_RESPONSE" ]]; then
        LATEST_SHA=$(echo "$REF_RESPONSE" | grep -o '"sha"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | cut -d'"' -f4)
    fi

    # Download using raw.githubusercontent with commit SHA (bypasses CDN)
    local DOWNLOAD_URL=""
    if [[ -n "$LATEST_SHA" && ${#LATEST_SHA} -eq 40 ]]; then
        DOWNLOAD_URL="https://raw.githubusercontent.com/${GITHUB_REPO}/${LATEST_SHA}/scripts/ozvps"
    else
        # Fallback to branch with cache-busting
        DOWNLOAD_URL="https://raw.githubusercontent.com/${GITHUB_REPO}/${BRANCH}/scripts/ozvps?$(date +%s)"
    fi

    if curl -fsSL "$DOWNLOAD_URL" -o "$TEMP_SCRIPT" 2>/dev/null; then
        if head -1 "$TEMP_SCRIPT" | grep -q "^#!/"; then
            local CURRENT_MD5=$(md5sum "$SELF_PATH" 2>/dev/null | cut -d' ' -f1)
            local NEW_MD5=$(md5sum "$TEMP_SCRIPT" 2>/dev/null | cut -d' ' -f1)

            if [ "$CURRENT_MD5" != "$NEW_MD5" ]; then
                echo -e "  ${GREEN}вњ“${NC} Control panel updated, restarting..."
                cp "$TEMP_SCRIPT" "$SELF_PATH"
                chmod +x "$SELF_PATH"
                rm -f "$TEMP_SCRIPT"
                exec "$SELF_PATH" --no-self-update "${SCRIPT_ARGS[@]}"
            fi
        fi
    fi

    rm -f "$TEMP_SCRIPT" 2>/dev/null
}

# ============================================================================
# Helper Functions
# ============================================================================
error() { echo -e "  ${RED}вњ—${NC} $1"; }
success() { echo -e "  ${GREEN}вњ“${NC} $1"; }
info() { echo -e "  ${CYAN}в†’${NC} $1"; }
warning() { echo -e "  ${YELLOW}вљ ${NC} $1"; }

get_environment() {
    # First check explicit .ozvps-env file
    if [[ -f "$INSTALL_DIR/.ozvps-env" ]]; then
        local env
        env=$(tr -d '[:space:]' < "$INSTALL_DIR/.ozvps-env" 2>/dev/null)
        if [[ -n "$env" ]]; then
            echo "$env"
            return
        fi
    fi

    # Fallback: detect from branch name
    local branch=$(get_branch)
    if [[ "$branch" == *"dev"* || "$branch" == *"develop"* || "$branch" == *"staging"* ]]; then
        echo "development"
        return
    fi

    # Default to production for main/master branches
    if [[ "$branch" == "main" || "$branch" == "master" ]]; then
        echo "production"
        return
    fi

    echo "unknown"
}

get_branch() {
    if [[ -f "$INSTALL_DIR/.ozvps-branch" ]]; then
        # Read first line and trim whitespace (preserving slashes in branch names like claude/dev-l5488)
        local branch
        branch=$(head -1 "$INSTALL_DIR/.ozvps-branch" 2>/dev/null | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        if [[ -n "$branch" ]]; then
            echo "$branch"
            return
        fi
    fi
    echo "main"
}

# Parse DATABASE_URL - format: postgresql://user:pass@host:port/dbname
parse_db_url() {
    local url="$1"
    local part="$2"

    # Remove postgresql:// prefix
    local stripped=$(echo "$url" | sed 's|^postgresql://||')

    case "$part" in
        user)
            echo "$stripped" | sed 's|:.*||'
            ;;
        host)
            echo "$stripped" | sed 's|.*@||' | sed 's|:.*||' | sed 's|/.*||'
            ;;
        port)
            echo "$stripped" | sed 's|.*@||' | sed 's|.*/.*||' | sed 's|.*:||'
            ;;
        dbname)
            echo "$stripped" | sed 's|.*@||' | sed 's|.*:||' | sed 's|.*/||' | sed 's|?.*||'
            ;;
    esac
}

get_app_status() {
    if ! pm2 describe "$SERVICE_NAME" &>/dev/null; then
        echo "stopped"
        return
    fi

    # Try jq first if available
    if command -v jq &>/dev/null; then
        local status=$(pm2 jlist 2>/dev/null | jq -r '.[] | select(.name=="'"$SERVICE_NAME"'") | .pm2_env.status' 2>/dev/null)
        if [[ -n "$status" ]]; then
            echo "$status"
            return
        fi
    fi

    # Fallback: parse pm2 show output
    local status=$(pm2 show "$SERVICE_NAME" 2>/dev/null | grep -E "^\в”‚ status" | awk '{print $4}')
    if [[ -n "$status" ]]; then
        echo "$status"
    else
        echo "unknown"
    fi
}

get_uptime() {
    if ! pm2 describe "$SERVICE_NAME" &>/dev/null; then
        echo "N/A"
        return
    fi

    # Try jq first if available
    if command -v jq &>/dev/null; then
        local uptime_ms=$(pm2 jlist 2>/dev/null | jq -r '.[] | select(.name=="'"$SERVICE_NAME"'") | .pm2_env.pm_uptime' 2>/dev/null)
        if [[ -n "$uptime_ms" && "$uptime_ms" != "null" ]]; then
            local now_ms=$(($(date +%s) * 1000))
            local diff_ms=$((now_ms - uptime_ms))
            local diff_sec=$((diff_ms / 1000))
            local days=$((diff_sec / 86400))
            local hours=$(((diff_sec % 86400) / 3600))
            local mins=$(((diff_sec % 3600) / 60))

            if [[ $days -gt 0 ]]; then
                echo "${days}d ${hours}h"
            elif [[ $hours -gt 0 ]]; then
                echo "${hours}h ${mins}m"
            else
                echo "${mins}m"
            fi
            return
        fi
    fi

    # Fallback: parse pm2 show output for uptime
    local uptime_str=$(pm2 show "$SERVICE_NAME" 2>/dev/null | grep -E "^\в”‚ uptime" | awk '{print $4}')
    if [[ -n "$uptime_str" ]]; then
        echo "$uptime_str"
    else
        echo "N/A"
    fi
}

check_db_connection() {
    if [[ -f "$INSTALL_DIR/.env" ]]; then
        local db_url=$(grep "^DATABASE_URL=" "$INSTALL_DIR/.env" | cut -d'=' -f2-)
        if [[ -n "$db_url" ]]; then
            # Extract host from DATABASE_URL
            if echo "$db_url" | grep -q "localhost\|127.0.0.1"; then
                if systemctl is-active postgresql &>/dev/null; then
                    echo "connected"
                    return
                fi
            fi
            # Try a quick connection test
            if timeout 2 bash -c "curl -s http://127.0.0.1:3000/api/health" &>/dev/null; then
                echo "connected"
                return
            fi
        fi
    fi
    echo "unknown"
}

# ============================================================================
# Show Header
# ============================================================================
show_header() {
    clear
    local env=$(get_environment)
    local branch=$(get_branch)
    local app_status=$(get_app_status)
    local uptime=$(get_uptime)
    local db_status=$(check_db_connection)

    # Status indicators
    local app_indicator="$STOPPED Stopped"
    if [[ "$app_status" == "online" ]]; then
        app_indicator="$RUNNING Running"
    elif [[ "$app_status" == "errored" ]]; then
        app_indicator="$WARNING Errored"
    fi

    local db_indicator="$WARNING Unknown"
    if [[ "$db_status" == "connected" ]]; then
        db_indicator="$RUNNING Connected"
    fi

    # Environment color
    local env_color="$GREEN"
    local env_display="PRODUCTION"
    if [[ "$env" == "development" ]]; then
        env_color="$YELLOW"
        env_display="DEVELOPMENT"
    fi

    echo ""
    echo -e "${CYAN}${BOLD}"
    cat << "EOF"
    в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—
    в•‘   в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в•—   в–€в–€в•—в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в–€в•—              в•‘
    в•‘  в–€в–€в•”в•ђв•ђв•ђв–€в–€в•—в•љв•ђв•ђв–€в–€в–€в•”в•ќв–€в–€в•‘   в–€в–€в•‘в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв•ђв•ќ              в•‘
    в•‘  в–€в–€в•‘   в–€в–€в•‘  в–€в–€в–€в•”в•ќ в–€в–€в•‘   в–€в–€в•‘в–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в–€в–€в•—              в•‘
    в•‘  в–€в–€в•‘   в–€в–€в•‘ в–€в–€в–€в•”в•ќ  в•љв–€в–€в•— в–€в–€в•”в•ќв–€в–€в•”в•ђв•ђв•ђв•ќ в•љв•ђв•ђв•ђв•ђв–€в–€в•‘              в•‘
    в•‘  в•љв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в–€в–€в•— в•љв–€в–€в–€в–€в•”в•ќ в–€в–€в•‘     в–€в–€в–€в–€в–€в–€в–€в•‘              в•‘
    в•‘   в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќ  в•љв•ђв•ђв•ђв•ќ  в•љв•ђв•ќ     в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќ              в•‘
EOF
    echo -e "    в•‘              ${NC}${BOLD}Control Panel v${VERSION}${CYAN}${BOLD}                       в•‘"
    echo -e "    в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
    echo ""
    echo -e "    Environment: ${env_color}${BOLD}${env_display}${NC} ${DIM}(${branch})${NC}"
