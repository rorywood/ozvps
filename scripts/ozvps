}

# ============================================================================
# Update Function (full update flow)
# ============================================================================
do_update() {
    local branch=$(get_branch)

    echo -e "${CYAN}${BOLD}"
    cat << "EOF"
    в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—
    в•‘                   Updating Application                    в•‘
    в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ
EOF
    echo -e "${NC}"
    echo -e "    Branch: ${BOLD}$branch${NC}"
    echo -e "    ${DIM}(from $INSTALL_DIR/.ozvps-branch)${NC}"
    echo ""

    # Verify branch file exists and show content for debugging
    if [[ ! -f "$INSTALL_DIR/.ozvps-branch" ]]; then
        warning "Branch file not found! Defaulting to 'main'"
        warning "Create it with: echo 'claude/dev-l5488' | sudo tee $INSTALL_DIR/.ozvps-branch"
    fi

    # Check for new commits first using refs API (more reliable)
    info "Checking for updates on $branch..."
    local latest_commit=""
    local ref_response=$(curl -fsSL "https://api.github.com/repos/${GITHUB_REPO}/git/ref/heads/${branch}" 2>/dev/null || true)
    if [[ -n "$ref_response" ]]; then
        latest_commit=$(echo "$ref_response" | grep -o '"sha"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | cut -d'"' -f4)
    fi

    # Step 0: Check for script updates using commit SHA
    info "Checking for control panel script updates..."
    local temp_script=$(mktemp)
    local self_path=$(readlink -f "$0" 2>/dev/null || echo "$0")

    # Download using raw.githubusercontent with commit SHA (bypasses CDN)
    local script_url=""
    if [[ -n "$latest_commit" && ${#latest_commit} -eq 40 ]]; then
        script_url="https://raw.githubusercontent.com/${GITHUB_REPO}/${latest_commit}/scripts/ozvps"
    else
        script_url="https://raw.githubusercontent.com/${GITHUB_REPO}/${branch}/scripts/ozvps?$(date +%s)"
    fi

    if curl -fsSL "$script_url" -o "$temp_script" 2>/dev/null && head -1 "$temp_script" | grep -q "^#!/"; then
        local current_md5=$(md5sum "$self_path" 2>/dev/null | cut -d' ' -f1)
        local new_md5=$(md5sum "$temp_script" 2>/dev/null | cut -d' ' -f1)

        if [[ "$current_md5" != "$new_md5" ]]; then
            success "New control panel version found, updating script..."
            cp "$temp_script" "$self_path"
            chmod +x "$self_path"
            rm -f "$temp_script"
            success "Script updated! Restarting update process..."
            echo ""
            exec "$self_path" --no-self-update --update
        else
            success "Control panel script is up to date"
        fi
    else
        warning "Could not check for script updates (continuing anyway)"
    fi
    rm -f "$temp_script" 2>/dev/null

    # Check application version
    local current_commit=""
    if [[ -f "$INSTALL_DIR/.commit" ]]; then
        current_commit=$(cat "$INSTALL_DIR/.commit" 2>/dev/null || echo "")
    fi

    if [[ -n "$latest_commit" && -n "$current_commit" && "$current_commit" == "$latest_commit" ]]; then
        success "Already on latest version (${latest_commit:0:7}) - will rebuild anyway"
    else
        if [[ -n "$current_commit" && -n "$latest_commit" ]]; then
            success "New version available!"
            echo -e "    Current: ${DIM}${current_commit:0:7}${NC}"
            echo -e "    Latest:  ${DIM}${latest_commit:0:7}${NC}"
        fi
    fi

    echo ""

    # Step 1: Backup
    info "Creating backup..."
    mkdir -p "$BACKUP_DIR"
    local backup_file="${BACKUP_DIR}/pre-update_$(date +%Y%m%d_%H%M%S).tar.gz"
    tar -czf "$backup_file" -C "$INSTALL_DIR" . 2>/dev/null || true
    success "Backup created"

    # Step 2: Download
    info "Downloading latest code..."
    local temp_dir=$(mktemp -d)
    cp "$INSTALL_DIR/.env" "$temp_dir/.env" 2>/dev/null || true
    cp "$INSTALL_DIR/ecosystem.config.cjs" "$temp_dir/ecosystem.config.cjs" 2>/dev/null || true
    cp "$INSTALL_DIR/.ozvps-branch" "$temp_dir/.ozvps-branch" 2>/dev/null || true
    cp "$INSTALL_DIR/.ozvps-env" "$temp_dir/.ozvps-env" 2>/dev/null || true

    local safe_branch=$(echo "$branch" | tr '/' '-')
    local temp_zip="/tmp/ozvps-update-${safe_branch}.zip"
    local temp_extract="/tmp/ozvps-update-${safe_branch}-extract"

    # Use codeload.github.com with commit SHA to bypass CDN caching
    local download_url=""
    if [[ -n "$latest_commit" && ${#latest_commit} -eq 40 ]]; then
        # Use commit-specific URL via codeload (not cached)
        download_url="https://codeload.github.com/${GITHUB_REPO}/zip/${latest_commit}"
    else
        # Fallback to branch with cache-busting
        download_url="https://codeload.github.com/${GITHUB_REPO}/zip/refs/heads/${branch}?$(date +%s)"
    fi

    if ! curl -fsSL "$download_url" -o "$temp_zip"; then
        error "Failed to download"
        return
    fi
    success "Downloaded"

    # Step 3: Extract
    info "Extracting..."
    find "$INSTALL_DIR" -mindepth 1 -maxdepth 1 ! -name 'node_modules' ! -name '.env' ! -name 'ecosystem.config.cjs' -exec rm -rf {} + 2>/dev/null || true

    rm -rf "$temp_extract" && mkdir -p "$temp_extract"
    unzip -q "$temp_zip" -d "$temp_extract"
    # Find extracted directory - handles both branch archives (ozvps-branch) and API zipball (owner-repo-sha)
    local extracted_dir=$(find "$temp_extract" -mindepth 1 -maxdepth 1 -type d | head -1)

    cp -r "${extracted_dir}"/* "$INSTALL_DIR/"
    cp -r "${extracted_dir}"/.[^.]* "$INSTALL_DIR/" 2>/dev/null || true

    cp "$temp_dir/.env" "$INSTALL_DIR/.env" 2>/dev/null || true
    cp "$temp_dir/ecosystem.config.cjs" "$INSTALL_DIR/ecosystem.config.cjs" 2>/dev/null || true
    cp "$temp_dir/.ozvps-branch" "$INSTALL_DIR/.ozvps-branch" 2>/dev/null || true
    cp "$temp_dir/.ozvps-env" "$INSTALL_DIR/.ozvps-env" 2>/dev/null || true
    rm -rf "$temp_dir" "$temp_extract" "$temp_zip"

    if [[ -n "$latest_commit" ]]; then
        echo "$latest_commit" > "$INSTALL_DIR/.commit"
    fi
    success "Code updated"

    # Step 4: Install dependencies
    info "Installing dependencies..."
    cd "$INSTALL_DIR"
    npm install --silent 2>&1 | grep -v "^npm " || true
    success "Dependencies installed"

    # Step 5: Build (clear all caches first)
    info "Clearing build caches..."
    rm -rf dist node_modules/.vite node_modules/.cache client/node_modules/.vite 2>/dev/null || true

    info "Building application..."
    npm run build
    if [[ ! -f "dist/index.cjs" ]]; then
        error "Build failed - dist/index.cjs not found"
        return
    fi
    success "Build complete"

    # Step 6: Migrations
    info "Running migrations..."
    set -a && source .env && set +a
    npx drizzle-kit push --force 2>/dev/null || true
    success "Migrations applied"

    # Step 6.5: Auto-configure APP_DOMAIN for Stripe webhooks
    info "Configuring domain for webhooks..."
    local domain=""

    # Try to detect domain from NGINX config (check multiple possible names)
    local nginx_conf_for_domain=""
    for conf in /etc/nginx/sites-available/ozvps /etc/nginx/sites-available/ozvps-dev /etc/nginx/sites-available/ozvps-prod; do
        if [[ -f "$conf" ]]; then
            nginx_conf_for_domain="$conf"
            break
        fi
    done
    if [[ -n "$nginx_conf_for_domain" ]]; then
        domain=$(grep -oP "server_name\s+\K[^;]+" "$nginx_conf_for_domain" 2>/dev/null | head -1 | tr -d ' ')
    fi

    # Fallback: try to get from hostname
    if [[ -z "$domain" ]]; then
        domain=$(hostname -f 2>/dev/null || hostname 2>/dev/null || echo "")
    fi

    if [[ -n "$domain" && "$domain" != "localhost" ]]; then
        # Check if APP_DOMAIN already exists in .env
        if grep -q "^APP_DOMAIN=" "$INSTALL_DIR/.env" 2>/dev/null; then
            # Update existing
            sed -i "s|^APP_DOMAIN=.*|APP_DOMAIN=$domain|" "$INSTALL_DIR/.env"
        else
            # Add new
            echo "APP_DOMAIN=$domain" >> "$INSTALL_DIR/.env"
        fi
        success "Webhook domain set to: $domain"
    else
        warning "Could not auto-detect domain for webhooks"
        warning "Manually add APP_DOMAIN=yourdomain.com to .env"
    fi

    # Step 7: Update NGINX error pages
    info "Updating NGINX error pages..."
    local error_pages_dir="/var/www/ozvps-errors"
    mkdir -p "$error_pages_dir"

    # Copy error pages and logo from deploy directory if they exist
    if [[ -d "$INSTALL_DIR/deploy/nginx-error-pages" ]]; then
        cp "$INSTALL_DIR/deploy/nginx-error-pages/"*.html "$error_pages_dir/" 2>/dev/null || true
        cp "$INSTALL_DIR/deploy/nginx-error-pages/"*.png "$error_pages_dir/" 2>/dev/null || true
        chmod 644 "$error_pages_dir/"* 2>/dev/null || true
        success "Error pages and logo copied to $error_pages_dir"
    else
        warning "Error pages source not found at $INSTALL_DIR/deploy/nginx-error-pages"
    fi

    # Create NGINX snippet for error pages (works with both HTTP and HTTPS)
    local snippets_dir="/etc/nginx/snippets"
    local snippet_file="$snippets_dir/ozvps-errors.conf"
    mkdir -p "$snippets_dir"

    cat > "$snippet_file" << 'ERRORCONF'
# OzVPS Custom Error Pages
error_page 404 /404.html;
error_page 500 /500.html;
error_page 502 /502.html;
error_page 503 /503.html;

location = /404.html { root /var/www/ozvps-errors; internal; }
location = /500.html { root /var/www/ozvps-errors; internal; }
location = /502.html { root /var/www/ozvps-errors; internal; }
location = /503.html { root /var/www/ozvps-errors; internal; }
location = /logo.png { root /var/www/ozvps-errors; }
ERRORCONF
    success "Error pages snippet created at $snippet_file"

    # Update NGINX config to include the snippet in ALL server blocks
    # Find the correct config file
    local nginx_conf=""
    if [[ -f "/etc/nginx/sites-available/ozvps" ]]; then
        nginx_conf="/etc/nginx/sites-available/ozvps"
    elif [[ -f "/etc/nginx/sites-available/ozvps-dev" ]]; then
        nginx_conf="/etc/nginx/sites-available/ozvps-dev"
    elif [[ -f "/etc/nginx/sites-available/ozvps-prod" ]]; then
        nginx_conf="/etc/nginx/sites-available/ozvps-prod"
    else
        nginx_conf=$(ls /etc/nginx/sites-available/ozvps* 2>/dev/null | head -1)
    fi

    if [[ -n "$nginx_conf" && -f "$nginx_conf" ]]; then
        # Check if snippet is already included
        if ! grep -q "include snippets/ozvps-errors.conf" "$nginx_conf"; then
            info "Adding error pages snippet to NGINX config..."

            # Insert include directive after EVERY server_name line (for both HTTP and HTTPS blocks)
            sed -i '/server_name/a\    include snippets/ozvps-errors.conf;' "$nginx_conf"

            # Test and reload NGINX
            if nginx -t 2>/dev/null; then
                systemctl reload nginx
                success "NGINX config updated with error pages"
            else
                warning "NGINX config test failed, reverting..."
                # Remove the include lines we just added
                sed -i '/include snippets\/ozvps-errors.conf/d' "$nginx_conf"
                warning "Reverted changes - check NGINX config manually"
            fi
        else
            info "Error pages snippet already included in NGINX config"
        fi
    else
        warning "NGINX config not found at $nginx_conf"
    fi

    # Step 8: Restart
    info "Restarting application..."
    pm2 delete "$SERVICE_NAME" 2>/dev/null || true
    pm2 start "$INSTALL_DIR/ecosystem.config.cjs"
    pm2 save --force
    success "Application restarted"

    # Wait for health
    info "Waiting for application..."
    for i in {1..30}; do
        if curl -s "http://127.0.0.1:3000/api/health" &>/dev/null; then
            success "Application is healthy"
            break
        fi
        sleep 1
        if [[ $i -eq 30 ]]; then
            warning "Health check timeout - check logs"
        fi
    done

    echo ""
    echo -e "${GREEN}${BOLD}Update Complete!${NC}"
    echo ""
}

# ============================================================================
# Main Menu Loop
# ============================================================================
main_menu() {
    while true; do
        show_header
        show_menu

        read -p "  Select option: " choice < /dev/tty

        case $choice in
            1) action_app_status ;;
            2) action_db_status ;;
            3) action_live_logs ;;
            4) action_system_resources ;;
            5) action_restart ;;
            6) action_stop ;;
            7) action_migrations ;;
            8) action_billing_job ;;
            9) action_update ;;
            10) action_backup ;;
            11) action_restore ;;
            12) action_renew_ssl ;;
            13) action_view_config ;;
            14) action_edit_env ;;
            15) action_test_email ;;
            q|Q) echo ""; info "Goodbye!"; exit 0 ;;
            *) warning "Invalid option" ;;
        esac
    done
}

# ============================================================================
# Branch Selection Menu
# ============================================================================
select_branch() {
    echo ""
    echo -e "${BOLD}Select Branch${NC}"
    echo -e "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    echo ""

    local current_branch=$(get_branch)
    echo -e "  Current: ${CYAN}${BOLD}$current_branch${NC}"
    echo ""

    # Fetch available branches from GitHub
    info "Fetching branches from GitHub..."
    local branches_json=$(curl -fsSL "https://api.github.com/repos/${GITHUB_REPO}/branches?per_page=20" 2>/dev/null)

    if [[ -z "$branches_json" ]]; then
        error "Could not fetch branches"
        return 1
    fi

    # Parse branch names
    local branches=($(echo "$branches_json" | grep '"name":' | cut -d'"' -f4))

    if [[ ${#branches[@]} -eq 0 ]]; then
        error "No branches found"
        return 1
    fi

    echo ""
    echo "  Available branches:"
    for i in "${!branches[@]}"; do
        local marker=""
        if [[ "${branches[$i]}" == "$current_branch" ]]; then
            marker=" ${GREEN}(current)${NC}"
        fi
        echo -e "    ${BOLD}[$((i+1))]${NC} ${branches[$i]}${marker}"
    done
    echo ""

    read -p "  Select branch number (or 0 to cancel): " branch_num < /dev/tty

    if [[ "$branch_num" == "0" || -z "$branch_num" ]]; then
        info "Cancelled"
        return 1
    fi

    local selected_branch="${branches[$((branch_num-1))]}"

    if [[ -z "$selected_branch" ]]; then
        error "Invalid selection"
        return 1
    fi

    # Save the branch
    echo "$selected_branch" > "$INSTALL_DIR/.ozvps-branch"
    success "Branch set to: $selected_branch"
    echo ""

    read -p "  Run update now? (y/N): " -n 1 -r < /dev/tty
    echo ""

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        do_update
    fi

    return 0
}

# ============================================================================
# Parse Arguments
# ============================================================================
SKIP_SELF_UPDATE=false
DIRECT_UPDATE=false
SHOW_STATUS=false
SELECT_BRANCH=false

for arg in "$@"; do
    case $arg in
        --no-self-update)
            SKIP_SELF_UPDATE=true
            ;;
        --update|-u)
            DIRECT_UPDATE=true
            ;;
        --status|-s)
            SHOW_STATUS=true
            ;;
        --branch|-b)
            SELECT_BRANCH=true
            ;;
        --version|-v)
            echo "OzVPS Control Panel v${VERSION}"
            exit 0
            ;;
        --help|-h)
            echo "OzVPS Control Panel v${VERSION}"
            echo ""
            echo "Usage: ozvps [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  (no args)     Open interactive control panel menu"
            echo "  --update, -u  Run update directly (no menu)"
            echo "  --branch, -b  Select branch from list"
            echo "  --status, -s  Show status dashboard and exit"
            echo "  --version     Show version"
            echo "  --help        Show this help message"
            exit 0
            ;;
    esac
done

# ============================================================================
# Main Entry Point
# ============================================================================

# Check root
if [[ $EUID -ne 0 ]]; then
    echo -e "${RED}Error:${NC} Must run as root (sudo ozvps)"
    exit 1
fi

# Check installation
if [[ ! -d "$INSTALL_DIR" ]]; then
    echo -e "${RED}Error:${NC} OzVPS not installed at $INSTALL_DIR"
    echo "Run the installer first: curl -fsSL ... | sudo bash"
    exit 1
fi

# Get script path for self-update
SELF_PATH="$(readlink -f "$0" 2>/dev/null || echo "$0")"

# Self-update check
if [[ "$SKIP_SELF_UPDATE" == "false" && -f "$SELF_PATH" ]]; then
    self_update "$SELF_PATH" "$@"
fi

# Handle direct commands
if [[ "$SELECT_BRANCH" == "true" ]]; then
    select_branch
    exit 0
fi

if [[ "$DIRECT_UPDATE" == "true" ]]; then
    show_header
    do_update
    exit 0
fi

if [[ "$SHOW_STATUS" == "true" ]]; then
    show_header
    exit 0
fi

# Run main menu
main_menu
