#!/usr/bin/env bash
set -e

# IMPORTANT: Start in a known good directory to avoid getcwd errors
# This fixes issues when running from a deleted directory
cd /tmp 2>/dev/null || cd /

# ============================================================================
#  OzVPS Control Panel
#  Version: 4.1.0
#
#  Usage:
#    ozvps              # Opens kiosk menu
#    ozvps --update     # Direct update (no menu)
#    ozvps --status     # Show status dashboard
#    ozvps --help       # Show help
# ============================================================================

VERSION="4.1.0"
INSTALL_DIR="/opt/ozvps-panel"
SERVICE_NAME="ozvps-panel"
GITHUB_REPO="rorywood/ozvps"
BACKUP_DIR="/opt/ozvps-backups"

# ============================================================================
# Colors and Styling
# ============================================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# Status indicators
RUNNING="${GREEN}●${NC}"
STOPPED="${RED}●${NC}"
WARNING="${YELLOW}●${NC}"

# ============================================================================
# Self-Update Function (runs silently at startup)
# ============================================================================
self_update() {
    local SELF_PATH="$1"
    shift
    local SCRIPT_ARGS=("$@")

    # Get branch from installation (use same logic as get_branch)
    local BRANCH="main"
    if [[ -f "$INSTALL_DIR/.ozvps-branch" ]]; then
        BRANCH=$(head -1 "$INSTALL_DIR/.ozvps-branch" 2>/dev/null | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [[ -z "$BRANCH" ]] && BRANCH="main"
    fi

    local TEMP_SCRIPT=$(mktemp)

    # Get latest commit SHA using refs API (more reliable)
    # URL-encode slashes in branch name for API compatibility
    local ENCODED_BRANCH=$(echo "$BRANCH" | sed 's|/|%2F|g')
    local LATEST_SHA=""
    local REF_RESPONSE=$(curl -fsSL "https://api.github.com/repos/${GITHUB_REPO}/git/ref/heads/${ENCODED_BRANCH}" 2>/dev/null || true)
    if [[ -n "$REF_RESPONSE" ]]; then
        LATEST_SHA=$(echo "$REF_RESPONSE" | grep -o '"sha"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | cut -d'"' -f4)
    fi

    # Download using raw.githubusercontent with commit SHA (bypasses CDN)
    local DOWNLOAD_URL=""
    if [[ -n "$LATEST_SHA" && ${#LATEST_SHA} -eq 40 ]]; then
        DOWNLOAD_URL="https://raw.githubusercontent.com/${GITHUB_REPO}/${LATEST_SHA}/scripts/ozvps"
    else
        # Fallback to branch with cache-busting
        DOWNLOAD_URL="https://raw.githubusercontent.com/${GITHUB_REPO}/${BRANCH}/scripts/ozvps?$(date +%s)"
    fi

    if curl -fsSL "$DOWNLOAD_URL" -o "$TEMP_SCRIPT" 2>/dev/null; then
        if head -1 "$TEMP_SCRIPT" | grep -q "^#!/"; then
            local CURRENT_MD5=$(md5sum "$SELF_PATH" 2>/dev/null | cut -d' ' -f1)
            local NEW_MD5=$(md5sum "$TEMP_SCRIPT" 2>/dev/null | cut -d' ' -f1)

            if [ "$CURRENT_MD5" != "$NEW_MD5" ]; then
                echo -e "  ${GREEN}✓${NC} Control panel updated, restarting..."
                cp "$TEMP_SCRIPT" "$SELF_PATH"
                chmod +x "$SELF_PATH"
                rm -f "$TEMP_SCRIPT"
                exec "$SELF_PATH" --no-self-update "${SCRIPT_ARGS[@]}"
            fi
        fi
    fi

    rm -f "$TEMP_SCRIPT" 2>/dev/null
}

# ============================================================================
# Helper Functions
# ============================================================================
error() { echo -e "  ${RED}✗${NC} $1"; }
success() { echo -e "  ${GREEN}✓${NC} $1"; }
info() { echo -e "  ${CYAN}→${NC} $1"; }
warning() { echo -e "  ${YELLOW}⚠${NC} $1"; }

get_environment() {
    # First check explicit .ozvps-env file
    if [[ -f "$INSTALL_DIR/.ozvps-env" ]]; then
        local env
        env=$(tr -d '[:space:]' < "$INSTALL_DIR/.ozvps-env" 2>/dev/null)
        if [[ -n "$env" ]]; then
            echo "$env"
            return
        fi
    fi

    # Fallback: detect from branch name
    local branch=$(get_branch)
    if [[ "$branch" == *"dev"* || "$branch" == *"develop"* || "$branch" == *"staging"* ]]; then
        echo "development"
        return
    fi

    # Default to production for main/master branches
    if [[ "$branch" == "main" || "$branch" == "master" ]]; then
        echo "production"
        return
    fi

    echo "unknown"
}

get_branch() {
    if [[ -f "$INSTALL_DIR/.ozvps-branch" ]]; then
        # Read first line and trim whitespace (preserving slashes in branch names like claude/dev-l5488)
        local branch
        branch=$(head -1 "$INSTALL_DIR/.ozvps-branch" 2>/dev/null | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        if [[ -n "$branch" ]]; then
            echo "$branch"
            return
        fi
    fi
    echo "main"
}

# Parse DATABASE_URL - format: postgresql://user:pass@host:port/dbname
parse_db_url() {
    local url="$1"
    local part="$2"

    # Remove postgresql:// prefix
    local stripped=$(echo "$url" | sed 's|^postgresql://||')

    case "$part" in
        user)
            echo "$stripped" | sed 's|:.*||'
            ;;
        host)
            echo "$stripped" | sed 's|.*@||' | sed 's|:.*||' | sed 's|/.*||'
            ;;
        port)
            echo "$stripped" | sed 's|.*@||' | sed 's|.*/.*||' | sed 's|.*:||'
            ;;
        dbname)
            echo "$stripped" | sed 's|.*@||' | sed 's|.*:||' | sed 's|.*/||' | sed 's|?.*||'
            ;;
    esac
}

get_app_status() {
    if ! pm2 describe "$SERVICE_NAME" &>/dev/null; then
        echo "stopped"
        return
    fi

    # Try jq first if available
    if command -v jq &>/dev/null; then
        local status=$(pm2 jlist 2>/dev/null | jq -r '.[] | select(.name=="'"$SERVICE_NAME"'") | .pm2_env.status' 2>/dev/null)
        if [[ -n "$status" ]]; then
            echo "$status"
            return
        fi
    fi

    # Fallback: parse pm2 show output
    local status=$(pm2 show "$SERVICE_NAME" 2>/dev/null | grep -E "^\│ status" | awk '{print $4}')
    if [[ -n "$status" ]]; then
        echo "$status"
    else
        echo "unknown"
    fi
}

get_uptime() {
    if ! pm2 describe "$SERVICE_NAME" &>/dev/null; then
        echo "N/A"
        return
    fi

    # Try jq first if available
    if command -v jq &>/dev/null; then
        local uptime_ms=$(pm2 jlist 2>/dev/null | jq -r '.[] | select(.name=="'"$SERVICE_NAME"'") | .pm2_env.pm_uptime' 2>/dev/null)
        if [[ -n "$uptime_ms" && "$uptime_ms" != "null" ]]; then
            local now_ms=$(($(date +%s) * 1000))
            local diff_ms=$((now_ms - uptime_ms))
            local diff_sec=$((diff_ms / 1000))
            local days=$((diff_sec / 86400))
            local hours=$(((diff_sec % 86400) / 3600))
            local mins=$(((diff_sec % 3600) / 60))

            if [[ $days -gt 0 ]]; then
                echo "${days}d ${hours}h"
            elif [[ $hours -gt 0 ]]; then
                echo "${hours}h ${mins}m"
            else
                echo "${mins}m"
            fi
            return
        fi
    fi

    # Fallback: parse pm2 show output for uptime
    local uptime_str=$(pm2 show "$SERVICE_NAME" 2>/dev/null | grep -E "^\│ uptime" | awk '{print $4}')
    if [[ -n "$uptime_str" ]]; then
        echo "$uptime_str"
    else
        echo "N/A"
    fi
}

check_db_connection() {
    if [[ -f "$INSTALL_DIR/.env" ]]; then
        local db_url=$(grep "^DATABASE_URL=" "$INSTALL_DIR/.env" | cut -d'=' -f2-)
        if [[ -n "$db_url" ]]; then
            # Extract host from DATABASE_URL
            if echo "$db_url" | grep -q "localhost\|127.0.0.1"; then
                if systemctl is-active postgresql &>/dev/null; then
                    echo "connected"
                    return
                fi
            fi
            # Try a quick connection test
            if timeout 2 bash -c "curl -s http://127.0.0.1:3000/api/health" &>/dev/null; then
                echo "connected"
                return
            fi
        fi
    fi
    echo "unknown"
}

# ============================================================================
# Show Header
# ============================================================================
show_header() {
    clear
    local env=$(get_environment)
    local branch=$(get_branch)
    local app_status=$(get_app_status)
    local uptime=$(get_uptime)
    local db_status=$(check_db_connection)

    # Status indicators
    local app_indicator="$STOPPED Stopped"
    if [[ "$app_status" == "online" ]]; then
        app_indicator="$RUNNING Running"
    elif [[ "$app_status" == "errored" ]]; then
        app_indicator="$WARNING Errored"
    fi

    local db_indicator="$WARNING Unknown"
    if [[ "$db_status" == "connected" ]]; then
        db_indicator="$RUNNING Connected"
    fi

    # Environment color
    local env_color="$GREEN"
    local env_display="PRODUCTION"
    if [[ "$env" == "development" ]]; then
        env_color="$YELLOW"
        env_display="DEVELOPMENT"
    fi

    echo ""
    echo -e "${CYAN}${BOLD}"
    cat << "EOF"
    ╔═══════════════════════════════════════════════════════════╗
    ║   ██████╗ ███████╗██╗   ██╗██████╗ ███████╗              ║
    ║  ██╔═══██╗╚══███╔╝██║   ██║██╔══██╗██╔════╝              ║
    ║  ██║   ██║  ███╔╝ ██║   ██║██████╔╝███████╗              ║
    ║  ██║   ██║ ███╔╝  ╚██╗ ██╔╝██╔═══╝ ╚════██║              ║
    ║  ╚██████╔╝███████╗ ╚████╔╝ ██║     ███████║              ║
    ║   ╚═════╝ ╚══════╝  ╚═══╝  ╚═╝     ╚══════╝              ║
EOF
    echo -e "    ║              ${NC}${BOLD}Control Panel v${VERSION}${CYAN}${BOLD}                       ║"
    echo -e "    ╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "    Environment: ${env_color}${BOLD}${env_display}${NC} ${DIM}(${branch})${NC}"
    echo -e "    App Status:  ${app_indicator}  |  DB: ${db_indicator}  |  Uptime: ${uptime}"
    echo ""
}

# ============================================================================
# Show Menu
# ============================================================================
show_menu() {
    echo -e "${CYAN}╭───────────────────────────────────────────────────────────╮${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}STATUS${NC}                                                  ${CYAN}│${NC}"
    echo -e "${CYAN}├───────────────────────────────────────────────────────────┤${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}[1]${NC} Application Status      ${BOLD}[2]${NC} Database Status          ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}[3]${NC} View Live Logs          ${BOLD}[4]${NC} System Resources         ${CYAN}│${NC}"
    echo -e "${CYAN}├───────────────────────────────────────────────────────────┤${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}MANAGEMENT${NC}                                             ${CYAN}│${NC}"
    echo -e "${CYAN}├───────────────────────────────────────────────────────────┤${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}[5]${NC} Restart Application     ${BOLD}[6]${NC} Stop Application         ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}[7]${NC} Run Database Migrations ${BOLD}[8]${NC} Run Billing Job          ${CYAN}│${NC}"
    echo -e "${CYAN}├───────────────────────────────────────────────────────────┤${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}MAINTENANCE${NC}                                            ${CYAN}│${NC}"
    echo -e "${CYAN}├───────────────────────────────────────────────────────────┤${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}[9]${NC} Update Application      ${BOLD}[10]${NC} Backup Database         ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}[11]${NC} Restore Backup         ${BOLD}[12]${NC} Renew SSL Certificate   ${CYAN}│${NC}"
    echo -e "${CYAN}├───────────────────────────────────────────────────────────┤${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}CONFIGURATION${NC}                                          ${CYAN}│${NC}"
    echo -e "${CYAN}├───────────────────────────────────────────────────────────┤${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}[13]${NC} View Configuration     ${BOLD}[14]${NC} Edit .env File          ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}[15]${NC} Test Email Config                                  ${CYAN}│${NC}"
    echo -e "${CYAN}├───────────────────────────────────────────────────────────┤${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}[Q]${NC} Quit                                               ${CYAN}│${NC}"
    echo -e "${CYAN}╰───────────────────────────────────────────────────────────╯${NC}"
    echo ""
}

# ============================================================================
# Menu Actions
# ============================================================================

# 1. Application Status
action_app_status() {
    echo ""
    echo -e "${BOLD}Application Status${NC}"
    echo -e "${DIM}─────────────────────────────────────────${NC}"
    pm2 describe "$SERVICE_NAME" 2>/dev/null || echo "Application not running"
    echo ""
    read -p "Press Enter to continue..." < /dev/tty
}

# 2. Database Status
action_db_status() {
    echo ""
    echo -e "${BOLD}Database Status${NC}"
    echo -e "${DIM}─────────────────────────────────────────${NC}"

    if [[ -f "$INSTALL_DIR/.env" ]]; then
        local db_url=$(grep "^DATABASE_URL=" "$INSTALL_DIR/.env" | cut -d'=' -f2-)
        local db_name=$(parse_db_url "$db_url" "dbname")
        local db_host=$(parse_db_url "$db_url" "host")
        local db_user=$(parse_db_url "$db_url" "user")

        echo -e "  Database: ${BOLD}${db_name:-unknown}${NC}"
        echo -e "  Host:     ${BOLD}${db_host:-unknown}${NC}"
        echo -e "  User:     ${BOLD}${db_user:-unknown}${NC}"
        echo ""

        # Try to get table count and size
        if command -v psql &>/dev/null && [[ "$db_host" == "localhost" || "$db_host" == "127.0.0.1" ]]; then
            echo -e "  ${DIM}Checking database...${NC}"

            # Count tables
            local table_count=$(sudo -u postgres psql -d "$db_name" -t -c "SELECT count(*) FROM information_schema.tables WHERE table_schema = 'public';" 2>/dev/null | tr -d ' ')

            if [[ -n "$table_count" && "$table_count" != "" ]]; then
                echo -e "  Tables:   ${BOLD}$table_count${NC}"

                # Get database size
                local db_size=$(sudo -u postgres psql -d "$db_name" -t -c "SELECT pg_size_pretty(pg_database_size('$db_name'));" 2>/dev/null | tr -d ' ')
                echo -e "  Size:     ${BOLD}$db_size${NC}"
                echo -e "  Status:   ${GREEN}✓${NC} Connected"
            else
                # Connection test
                if sudo -u postgres psql -d "$db_name" -c "SELECT 1" &>/dev/null; then
                    echo -e "  Status:   ${GREEN}✓${NC} Connected"
                else
                    echo -e "  Status:   ${RED}✗${NC} Connection failed"
                fi
            fi
        else
            echo -e "  ${DIM}(psql not available or remote database)${NC}"
        fi
    else
        error ".env file not found"
    fi

    echo ""
    read -p "Press Enter to continue..." < /dev/tty
}

# 3. View Live Logs
action_live_logs() {
    echo ""
    echo -e "${BOLD}Live Logs${NC} ${DIM}(Ctrl+C to exit)${NC}"
    echo -e "${DIM}─────────────────────────────────────────${NC}"
    pm2 logs "$SERVICE_NAME" --lines 50
}

# 4. System Resources
action_system_resources() {
    echo ""
    echo -e "${BOLD}System Resources${NC}"
    echo -e "${DIM}─────────────────────────────────────────${NC}"
    echo ""

    # CPU
    local cpu_usage=$(top -bn1 | grep "Cpu(s)" | awk '{print $2}' | cut -d'%' -f1 2>/dev/null || echo "N/A")
    echo -e "  CPU Usage:    ${BOLD}${cpu_usage}%${NC}"

    # Memory
    local mem_info=$(free -h 2>/dev/null | grep Mem)
    local mem_total=$(echo "$mem_info" | awk '{print $2}')
    local mem_used=$(echo "$mem_info" | awk '{print $3}')
    echo -e "  Memory:       ${BOLD}${mem_used}${NC} / ${mem_total}"

    # Disk
    local disk_info=$(df -h / 2>/dev/null | tail -1)
    local disk_used=$(echo "$disk_info" | awk '{print $3}')
    local disk_total=$(echo "$disk_info" | awk '{print $2}')
    local disk_pct=$(echo "$disk_info" | awk '{print $5}')
    echo -e "  Disk (root):  ${BOLD}${disk_used}${NC} / ${disk_total} (${disk_pct})"

    # App memory
    local app_mem=$(pm2 jlist 2>/dev/null | grep -o '"name":"'$SERVICE_NAME'"[^}]*"memory":[0-9]*' | grep -o '"memory":[0-9]*' | cut -d':' -f2)
    if [[ -n "$app_mem" ]]; then
        local app_mem_mb=$((app_mem / 1024 / 1024))
        echo -e "  App Memory:   ${BOLD}${app_mem_mb}MB${NC}"
    fi

    echo ""
    read -p "Press Enter to continue..." < /dev/tty
}

# 5. Restart Application
action_restart() {
    echo ""
    echo -e "${YELLOW}Restart Application?${NC}"
    read -p "  Are you sure? (y/N): " -n 1 -r < /dev/tty
    echo ""

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        info "Restarting application..."
        pm2 restart "$SERVICE_NAME"
        success "Application restarted"
        sleep 2
    else
        info "Cancelled"
    fi

    read -p "Press Enter to continue..." < /dev/tty
}

# 6. Stop Application
action_stop() {
    echo ""
    echo -e "${RED}${BOLD}Stop Application?${NC}"
    echo -e "${YELLOW}⚠ This will make the panel unavailable!${NC}"
    read -p "  Are you sure? (y/N): " -n 1 -r < /dev/tty
    echo ""

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        info "Stopping application..."
        pm2 stop "$SERVICE_NAME"
        success "Application stopped"
    else
        info "Cancelled"
    fi

    read -p "Press Enter to continue..." < /dev/tty
}

# 7. Run Database Migrations
action_migrations() {
    echo ""
    echo -e "${BOLD}Run Database Migrations${NC}"
    read -p "  Continue? (y/N): " -n 1 -r < /dev/tty
    echo ""

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        cd "$INSTALL_DIR"
        set -a && source .env && set +a
        info "Running migrations..."
        npx drizzle-kit push --force
        success "Migrations complete"
    else
        info "Cancelled"
    fi

    read -p "Press Enter to continue..." < /dev/tty
}

# 8. Run Billing Job
action_billing_job() {
    echo ""
    echo -e "${BOLD}Run Billing Job${NC}"
    echo -e "${DIM}This will calculate and apply billing for active servers${NC}"
    read -p "  Continue? (y/N): " -n 1 -r < /dev/tty
    echo ""

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        info "Running billing job..."
        local response=$(curl -s -X POST http://127.0.0.1:3000/api/admin/billing/run-job 2>/dev/null)
        if echo "$response" | grep -q "success\|processed"; then
            success "Billing job completed"
            echo -e "  ${DIM}$response${NC}"
        else
            error "Billing job may have failed"
            echo -e "  ${DIM}$response${NC}"
        fi
    else
        info "Cancelled"
    fi

    read -p "Press Enter to continue..." < /dev/tty
}

# 9. Update Application
action_update() {
    echo ""
    do_update
    read -p "Press Enter to continue..." < /dev/tty
}

# 10. Backup Database
action_backup() {
    echo ""
    echo -e "${BOLD}Backup Database${NC}"

    mkdir -p "$BACKUP_DIR"

    if [[ -f "$INSTALL_DIR/.env" ]]; then
        local db_url=$(grep "^DATABASE_URL=" "$INSTALL_DIR/.env" | cut -d'=' -f2-)
        local db_name=$(parse_db_url "$db_url" "dbname")

        local backup_file="${BACKUP_DIR}/${db_name}_$(date +%Y%m%d_%H%M%S).sql.gz"

        info "Creating backup: $backup_file"

        if sudo -u postgres pg_dump "$db_name" | gzip > "$backup_file" 2>/dev/null; then
            local backup_size=$(du -sh "$backup_file" 2>/dev/null | cut -f1)
            success "Backup created ($backup_size)"

            # Keep only last 5 backups
            local backup_count=$(ls -1 "${BACKUP_DIR}/${db_name}_"*.sql.gz 2>/dev/null | wc -l)
            if [[ $backup_count -gt 5 ]]; then
                info "Cleaning old backups (keeping last 5)..."
                ls -1t "${BACKUP_DIR}/${db_name}_"*.sql.gz | tail -n +6 | xargs rm -f
            fi
        else
            error "Backup failed"
        fi
    else
        error ".env file not found"
    fi

    read -p "Press Enter to continue..." < /dev/tty
}

# 11. Restore Backup
action_restore() {
    echo ""
    echo -e "${BOLD}Restore Backup${NC}"
    echo -e "${DIM}─────────────────────────────────────────${NC}"

    # List available backups
    local backups=($(ls -1t "${BACKUP_DIR}/"*.sql.gz 2>/dev/null))

    if [[ ${#backups[@]} -eq 0 ]]; then
        warning "No backups found in $BACKUP_DIR"
        read -p "Press Enter to continue..." < /dev/tty
        return
    fi

    echo "  Available backups:"
    for i in "${!backups[@]}"; do
        local backup_name=$(basename "${backups[$i]}")
        local backup_size=$(du -sh "${backups[$i]}" 2>/dev/null | cut -f1)
        echo -e "    ${BOLD}[$((i+1))]${NC} $backup_name ($backup_size)"
    done
    echo ""

    read -p "  Select backup number (or 0 to cancel): " backup_num < /dev/tty

    if [[ "$backup_num" == "0" || -z "$backup_num" ]]; then
        info "Cancelled"
        read -p "Press Enter to continue..." < /dev/tty
        return
    fi

    local selected_backup="${backups[$((backup_num-1))]}"
    if [[ -z "$selected_backup" || ! -f "$selected_backup" ]]; then
        error "Invalid selection"
        read -p "Press Enter to continue..." < /dev/tty
        return
    fi

    echo ""
    echo -e "${RED}${BOLD}WARNING: This will overwrite the current database!${NC}"
    read -p "  Type 'restore' to confirm: " confirm < /dev/tty

    if [[ "$confirm" != "restore" ]]; then
        info "Cancelled"
        read -p "Press Enter to continue..." < /dev/tty
        return
    fi

    if [[ -f "$INSTALL_DIR/.env" ]]; then
        local db_url=$(grep "^DATABASE_URL=" "$INSTALL_DIR/.env" | cut -d'=' -f2-)
        local db_name=$(echo "$db_url" | grep -oP '\/\K[^?]+' | head -1)

        info "Stopping application..."
        pm2 stop "$SERVICE_NAME" 2>/dev/null || true

        info "Restoring database..."
        if gunzip -c "$selected_backup" | sudo -u postgres psql "$db_name" &>/dev/null; then
            success "Database restored"
        else
            error "Restore failed"
        fi

        info "Starting application..."
        pm2 start "$SERVICE_NAME"
    fi

    read -p "Press Enter to continue..." < /dev/tty
}

# 12. Renew SSL Certificate
action_renew_ssl() {
    echo ""
    echo -e "${BOLD}Renew SSL Certificate${NC}"
    read -p "  Force renewal? (y/N): " -n 1 -r < /dev/tty
    echo ""

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        info "Renewing SSL certificate..."
        if certbot renew --force-renewal; then
            success "SSL certificate renewed"
            systemctl reload nginx
        else
            error "SSL renewal failed"
        fi
    else
        info "Checking certificate status..."
        certbot certificates
    fi

    read -p "Press Enter to continue..." < /dev/tty
}

# 13. View Configuration
action_view_config() {
    echo ""
    echo -e "${BOLD}Configuration${NC} ${DIM}(secrets masked)${NC}"
    echo -e "${DIM}─────────────────────────────────────────${NC}"

    if [[ -f "$INSTALL_DIR/.env" ]]; then
        while IFS= read -r line; do
            # Skip comments and empty lines
            if [[ "$line" =~ ^# ]] || [[ -z "$line" ]]; then
                echo -e "${DIM}$line${NC}"
                continue
            fi

            # Mask secrets
            if echo "$line" | grep -qiE "(secret|token|password|key|dsn)"; then
                local key=$(echo "$line" | cut -d'=' -f1)
                echo -e "  ${BOLD}$key${NC}=********"
            else
                local key=$(echo "$line" | cut -d'=' -f1)
                local value=$(echo "$line" | cut -d'=' -f2-)
                echo -e "  ${BOLD}$key${NC}=$value"
            fi
        done < "$INSTALL_DIR/.env"
    else
        error ".env file not found"
    fi

    echo ""
    read -p "Press Enter to continue..." < /dev/tty
}

# 14. Edit .env File
action_edit_env() {
    local editor="${EDITOR:-nano}"
    echo ""
    info "Opening .env with $editor..."
    $editor "$INSTALL_DIR/.env"
    echo ""
    warning "Changes require a restart to take effect"
    read -p "  Restart now? (y/N): " -n 1 -r < /dev/tty
    echo ""

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        pm2 restart "$SERVICE_NAME"
        success "Application restarted"
    fi
}

# 15. Test Email Config
action_test_email() {
    echo ""
    echo -e "${BOLD}Test Email Configuration${NC}"
    read -p "  Enter email address to test: " test_email < /dev/tty

    if [[ -n "$test_email" ]]; then
        info "Sending test email to $test_email..."
        local response=$(curl -s -X POST "http://127.0.0.1:3000/api/admin/test-email" \
            -H "Content-Type: application/json" \
            -d "{\"email\":\"$test_email\"}" 2>/dev/null)

        if echo "$response" | grep -q "success\|sent"; then
            success "Test email sent"
        else
            error "Failed to send test email"
            echo -e "  ${DIM}$response${NC}"
        fi
    else
        info "Cancelled"
    fi

    read -p "Press Enter to continue..." < /dev/tty
}

# ============================================================================
# Update Function (Git-based - no more cache issues!)
# ============================================================================
do_update() {
    local branch=$(get_branch)
    local REPO_URL="https://github.com/${GITHUB_REPO}.git"

    echo -e "${CYAN}${BOLD}"
    cat << "EOF"
    ╔═══════════════════════════════════════════════════════════╗
    ║              Updating Application (Git-based)             ║
    ╚═══════════════════════════════════════════════════════════╝
EOF
    echo -e "${NC}"
    echo -e "    Branch: ${BOLD}$branch${NC}"
    echo ""

    cd "$INSTALL_DIR"

    # Check if it's already a git repo
    if [[ -d ".git" ]]; then
        success "Git repository detected"

        # Fetch and check for updates
        info "Fetching latest changes..."
        git fetch origin "$branch" 2>/dev/null || {
            error "Failed to fetch from origin"
            return 1
        }

        local LOCAL=$(git rev-parse HEAD 2>/dev/null || echo "none")
        local REMOTE=$(git rev-parse "origin/$branch" 2>/dev/null || echo "none")

        if [[ "$LOCAL" == "$REMOTE" ]]; then
            success "Already up to date!"
            echo -e "    Current commit: ${DIM}${LOCAL:0:7}${NC}"
            echo ""
            info "Rebuilding anyway to ensure consistency..."
        else
            echo -e "    Current: ${DIM}${LOCAL:0:7}${NC}"
            echo -e "    Latest:  ${DIM}${REMOTE:0:7}${NC}"
            echo ""

            # Show recent commits
            info "New commits:"
            git log --oneline HEAD..origin/$branch 2>/dev/null | head -10
            echo ""

            # Stop app before pulling
            info "Stopping application..."
            pm2 stop "$SERVICE_NAME" 2>/dev/null || true

            # Pull changes (hard reset to handle any local modifications)
            info "Pulling changes..."
            git reset --hard "origin/$branch"
            success "Code updated to ${REMOTE:0:7}"
        fi

    else
        # Not a git repo - convert from zip-based to git-based
        warning "Not a git repo - converting to git-based installation"
        echo ""

        # Backup critical files
        local temp_backup=$(mktemp -d)
        info "Backing up configuration..."
        cp .env "$temp_backup/.env" 2>/dev/null || true
        cp ecosystem.config.cjs "$temp_backup/ecosystem.config.cjs" 2>/dev/null || true
        cp .ozvps-branch "$temp_backup/.ozvps-branch" 2>/dev/null || true
        cp .ozvps-env "$temp_backup/.ozvps-env" 2>/dev/null || true
        success "Configuration backed up"

        # Stop app
        info "Stopping application..."
        pm2 stop "$SERVICE_NAME" 2>/dev/null || true

        # Remove old installation and clone fresh
        cd /opt
        rm -rf ozvps-panel

        info "Cloning repository..."
        if ! git clone -b "$branch" "$REPO_URL" ozvps-panel 2>/dev/null; then
            error "Failed to clone repository"
            # Try to restore from backup
            mkdir -p ozvps-panel
            cp "$temp_backup"/* ozvps-panel/ 2>/dev/null || true
            rm -rf "$temp_backup"
            return 1
        fi
        cd ozvps-panel
        success "Repository cloned"

        # Restore configuration
        info "Restoring configuration..."
        cp "$temp_backup/.env" .env 2>/dev/null || warning "No .env backup found"
        cp "$temp_backup/ecosystem.config.cjs" ecosystem.config.cjs 2>/dev/null || true
        cp "$temp_backup/.ozvps-branch" .ozvps-branch 2>/dev/null || true
        cp "$temp_backup/.ozvps-env" .ozvps-env 2>/dev/null || true
        rm -rf "$temp_backup"
        success "Configuration restored"
    fi

    # IMPORTANT: Re-enter the install directory with a fresh reference
    # This fixes "getcwd: cannot access parent directories" error after rm/clone
    cd /opt
    cd "$INSTALL_DIR" || {
        error "Failed to enter $INSTALL_DIR"
        return 1
    }

    # Save environment markers
    echo "$(get_environment)" > .ozvps-env 2>/dev/null || true
    echo "$branch" > .ozvps-branch

    # Install dependencies
    echo ""
    info "Installing dependencies..."
    npm install --silent 2>&1 | grep -v "^npm " || true
    success "Dependencies installed"

    # Build (clear all caches first)
    info "Clearing build caches..."
    rm -rf dist node_modules/.vite node_modules/.cache client/node_modules/.vite 2>/dev/null || true

    info "Building application..."
    npm run build
    if [[ ! -f "dist/index.cjs" ]]; then
        error "Build failed - dist/index.cjs not found"
        return 1
    fi
    success "Build complete"

    # Migrations
    info "Running migrations..."
    set -a && source .env && set +a
    npx drizzle-kit push --force 2>/dev/null || true
    success "Migrations applied"

    # Auto-configure APP_DOMAIN for Stripe webhooks
    info "Configuring domain for webhooks..."
    local domain=""

    # Try to detect domain from NGINX config
    local nginx_conf_for_domain=""
    for conf in /etc/nginx/sites-available/ozvps /etc/nginx/sites-available/ozvps-dev /etc/nginx/sites-available/ozvps-prod; do
        if [[ -f "$conf" ]]; then
            nginx_conf_for_domain="$conf"
            break
        fi
    done
    if [[ -n "$nginx_conf_for_domain" ]]; then
        domain=$(grep -oP "server_name\s+\K[^;]+" "$nginx_conf_for_domain" 2>/dev/null | head -1 | tr -d ' ')
    fi

    # Fallback: try to get from hostname
    if [[ -z "$domain" ]]; then
        domain=$(hostname -f 2>/dev/null || hostname 2>/dev/null || echo "")
    fi

    if [[ -n "$domain" && "$domain" != "localhost" ]]; then
        if grep -q "^APP_DOMAIN=" "$INSTALL_DIR/.env" 2>/dev/null; then
            sed -i "s|^APP_DOMAIN=.*|APP_DOMAIN=$domain|" "$INSTALL_DIR/.env"
        else
            echo "APP_DOMAIN=$domain" >> "$INSTALL_DIR/.env"
        fi
        success "Webhook domain set to: $domain"
    else
        warning "Could not auto-detect domain for webhooks"
    fi

    # Update NGINX error pages
    info "Updating NGINX error pages..."
    local error_pages_dir="/var/www/ozvps-errors"
    mkdir -p "$error_pages_dir"

    if [[ -d "$INSTALL_DIR/deploy/nginx-error-pages" ]]; then
        cp "$INSTALL_DIR/deploy/nginx-error-pages/"*.html "$error_pages_dir/" 2>/dev/null || true
        cp "$INSTALL_DIR/deploy/nginx-error-pages/"*.png "$error_pages_dir/" 2>/dev/null || true
        chmod 644 "$error_pages_dir/"* 2>/dev/null || true
        success "Error pages updated"
    fi

    # Create/update NGINX snippet for error pages
    local snippets_dir="/etc/nginx/snippets"
    local snippet_file="$snippets_dir/ozvps-errors.conf"
    mkdir -p "$snippets_dir"

    cat > "$snippet_file" << 'ERRORCONF'
# OzVPS Custom Error Pages
error_page 404 /404.html;
error_page 500 /500.html;
error_page 502 /502.html;
error_page 503 /503.html;

location = /404.html { root /var/www/ozvps-errors; internal; }
location = /500.html { root /var/www/ozvps-errors; internal; }
location = /502.html { root /var/www/ozvps-errors; internal; }
location = /503.html { root /var/www/ozvps-errors; internal; }
location = /logo.png { root /var/www/ozvps-errors; }
ERRORCONF

    # Add snippet to NGINX config if not already present
    local nginx_conf=""
    for conf in /etc/nginx/sites-available/ozvps /etc/nginx/sites-available/ozvps-dev /etc/nginx/sites-available/ozvps-prod; do
        if [[ -f "$conf" ]]; then
            nginx_conf="$conf"
            break
        fi
    done

    if [[ -n "$nginx_conf" && -f "$nginx_conf" ]]; then
        if ! grep -q "include snippets/ozvps-errors.conf" "$nginx_conf"; then
            sed -i '/server_name/a\    include snippets/ozvps-errors.conf;' "$nginx_conf"
            if nginx -t 2>/dev/null; then
                systemctl reload nginx
                success "NGINX config updated with error pages"
            else
                sed -i '/include snippets\/ozvps-errors.conf/d' "$nginx_conf"
                warning "NGINX config test failed, reverted"
            fi
        fi
    fi

    # Restart application
    info "Starting application..."
    pm2 delete "$SERVICE_NAME" 2>/dev/null || true
    pm2 start "$INSTALL_DIR/ecosystem.config.cjs"
    pm2 save --force
    success "Application started"

    # Wait for health
    info "Waiting for application..."
    for i in {1..30}; do
        if curl -s "http://127.0.0.1:3000/api/health" &>/dev/null; then
            success "Application is healthy"
            break
        fi
        sleep 1
        if [[ $i -eq 30 ]]; then
            warning "Health check timeout - check logs with: pm2 logs ozvps-panel"
        fi
    done

    echo ""
    echo -e "${GREEN}${BOLD}Update Complete!${NC}"
    echo ""
    echo -e "    Branch: ${BOLD}$branch${NC}"
    echo -e "    Commit: ${BOLD}$(git rev-parse --short HEAD 2>/dev/null || echo 'unknown')${NC}"
    echo ""
    echo "Commands:"
    echo "  pm2 logs ozvps-panel  - View logs"
    echo "  pm2 status            - Check status"
    echo ""
}

# ============================================================================
# Main Menu Loop
# ============================================================================
main_menu() {
    while true; do
        show_header
        show_menu

        read -p "  Select option: " choice < /dev/tty

        case $choice in
            1) action_app_status ;;
            2) action_db_status ;;
            3) action_live_logs ;;
            4) action_system_resources ;;
            5) action_restart ;;
            6) action_stop ;;
            7) action_migrations ;;
            8) action_billing_job ;;
            9) action_update ;;
            10) action_backup ;;
            11) action_restore ;;
            12) action_renew_ssl ;;
            13) action_view_config ;;
            14) action_edit_env ;;
            15) action_test_email ;;
            q|Q) echo ""; info "Goodbye!"; exit 0 ;;
            *) warning "Invalid option" ;;
        esac
    done
}

# ============================================================================
# Branch Selection Menu
# ============================================================================
select_branch() {
    echo ""
    echo -e "${BOLD}Select Branch${NC}"
    echo -e "${DIM}─────────────────────────────────────────${NC}"
    echo ""

    local current_branch=$(get_branch)
    echo -e "  Current: ${CYAN}${BOLD}$current_branch${NC}"
    echo ""

    # Fetch available branches from GitHub
    info "Fetching branches from GitHub..."
    local branches_json=$(curl -fsSL "https://api.github.com/repos/${GITHUB_REPO}/branches?per_page=20" 2>/dev/null)

    if [[ -z "$branches_json" ]]; then
        error "Could not fetch branches"
        return 1
    fi

    # Parse branch names
    local branches=($(echo "$branches_json" | grep '"name":' | cut -d'"' -f4))

    if [[ ${#branches[@]} -eq 0 ]]; then
        error "No branches found"
        return 1
    fi

    echo ""
    echo "  Available branches:"
    for i in "${!branches[@]}"; do
        local marker=""
        if [[ "${branches[$i]}" == "$current_branch" ]]; then
            marker=" ${GREEN}(current)${NC}"
        fi
        echo -e "    ${BOLD}[$((i+1))]${NC} ${branches[$i]}${marker}"
    done
    echo ""

    read -p "  Select branch number (or 0 to cancel): " branch_num < /dev/tty

    if [[ "$branch_num" == "0" || -z "$branch_num" ]]; then
        info "Cancelled"
        return 1
    fi

    local selected_branch="${branches[$((branch_num-1))]}"

    if [[ -z "$selected_branch" ]]; then
        error "Invalid selection"
        return 1
    fi

    # Save the branch
    echo "$selected_branch" > "$INSTALL_DIR/.ozvps-branch"
    success "Branch set to: $selected_branch"
    echo ""

    read -p "  Run update now? (y/N): " -n 1 -r < /dev/tty
    echo ""

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        do_update
    fi

    return 0
}

# ============================================================================
# Parse Arguments
# ============================================================================
SKIP_SELF_UPDATE=false
DIRECT_UPDATE=false
SHOW_STATUS=false
SELECT_BRANCH=false

for arg in "$@"; do
    case $arg in
        --no-self-update)
            SKIP_SELF_UPDATE=true
            ;;
        --update|-u)
            DIRECT_UPDATE=true
            ;;
        --status|-s)
            SHOW_STATUS=true
            ;;
        --branch|-b)
            SELECT_BRANCH=true
            ;;
        --version|-v)
            echo "OzVPS Control Panel v${VERSION}"
            exit 0
            ;;
        --help|-h)
            echo "OzVPS Control Panel v${VERSION}"
            echo ""
            echo "Usage: ozvps [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  (no args)     Open interactive control panel menu"
            echo "  --update, -u  Run update directly (no menu)"
            echo "  --branch, -b  Select branch from list"
            echo "  --status, -s  Show status dashboard and exit"
            echo "  --version     Show version"
            echo "  --help        Show this help message"
            exit 0
            ;;
    esac
done

# ============================================================================
# Main Entry Point
# ============================================================================

# Check root
if [[ $EUID -ne 0 ]]; then
    echo -e "${RED}Error:${NC} Must run as root (sudo ozvps)"
    exit 1
fi

# Check installation
if [[ ! -d "$INSTALL_DIR" ]]; then
    echo -e "${RED}Error:${NC} OzVPS not installed at $INSTALL_DIR"
    echo "Run the installer first: curl -fsSL ... | sudo bash"
    exit 1
fi

# Get script path for self-update
SELF_PATH="$(readlink -f "$0" 2>/dev/null || echo "$0")"

# Self-update check
if [[ "$SKIP_SELF_UPDATE" == "false" && -f "$SELF_PATH" ]]; then
    self_update "$SELF_PATH" "$@"
fi

# Handle direct commands
if [[ "$SELECT_BRANCH" == "true" ]]; then
    select_branch
    exit 0
fi

if [[ "$DIRECT_UPDATE" == "true" ]]; then
    show_header
    do_update
    exit 0
fi

if [[ "$SHOW_STATUS" == "true" ]]; then
    show_header
    exit 0
fi

# Run main menu
main_menu
