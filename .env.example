# OzVPS Panel - Environment Configuration
# Copy this file to .env and fill in your values
#
# REQUIRED variables will prevent startup if missing
# RECOMMENDED variables will show warnings if missing
# OPTIONAL variables have sensible defaults

# ===========================================
# APPLICATION SETTINGS
# ===========================================
# Environment: development | production
NODE_ENV=production

# Server port (default: 5000)
PORT=5000

# Public URL of the application (used for email links, etc.)
APP_URL=https://your-domain.com

# Disable new user registration (true/false)
REGISTRATION_DISABLED=false

# ===========================================
# SECURITY (REQUIRED FOR PRODUCTION)
# ===========================================
# Session secret - min 32 characters, use: openssl rand -base64 32
SESSION_SECRET=your_secure_session_secret_min_32_chars

# TOTP encryption key for 2FA - min 32 characters, use: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=your_secure_totp_key_min_32_chars

# Session IP validation - rejects sessions where the client IP changes (anti session-hijacking)
# Requires TRUST_PROXY=true to work correctly behind nginx. Can log out mobile users on network change.
SESSION_VALIDATE_IP=true

# Trust proxy headers (X-Forwarded-For) - set true when behind nginx/load balancer
TRUST_PROXY=true

# ===========================================
# DATABASE CONFIGURATION (REQUIRED)
# ===========================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://ozvps:your_secure_database_password@localhost:5432/ozvps

# ===========================================
# REDIS CONFIGURATION (Session Storage) - OPTIONAL
# ===========================================
# Redis connection URL (for distributed session storage across PM2 instances)
#
# LEAVE BLANK OR COMMENT OUT to use memory-based sessions (simple deployments)
# SET THIS VALUE for production deployments requiring session persistence across PM2 restarts
#
# Format: redis://[password@]host:port
# Example: redis://localhost:6379
#
# If not configured, the app will automatically use memory-based sessions
# REDIS_URL=redis://redis:6379

# Redis password (optional, but recommended for production)
# REDIS_PASSWORD=your_redis_password_here

# ===========================================
# ERROR TRACKING (OPTIONAL) - Sentry
# ===========================================
# Sentry DSN for error tracking and monitoring
# Get this from your Sentry project settings: https://sentry.io
# Leave blank to disable error tracking
# SENTRY_DSN=https://your_sentry_dsn@sentry.io/your_project_id

# Sentry environment (defaults to NODE_ENV)
# SENTRY_ENVIRONMENT=production

# ===========================================
# VIRTFUSION API CONFIGURATION
# ===========================================
# Your VirtFusion panel URL (without trailing slash)
VIRTFUSION_PANEL_URL=https://your-virtfusion-panel.com

# VirtFusion API token (generate from VirtFusion admin panel)
VIRTFUSION_API_TOKEN=your_virtfusion_api_token_here

# ===========================================
# AUTH0 CONFIGURATION
# ===========================================
# Auth0 domain (e.g., your-app.au.auth0.com)
AUTH0_DOMAIN=your-app.au.auth0.com

# Auth0 application Client ID
AUTH0_CLIENT_ID=your_auth0_client_id_here

# Auth0 application Client Secret
AUTH0_CLIENT_SECRET=your_auth0_client_secret_here

# Auth0 webhook secret (for user deletion sync)
AUTH0_WEBHOOK_SECRET=your_auth0_webhook_secret_here

# ===========================================
# STRIPE CONFIGURATION
# ===========================================
# Stripe Secret Key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here

# Stripe Publishable Key (starts with pk_live_ or pk_test_)
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here

# Stripe Webhook Secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ===========================================
# EMAIL CONFIGURATION (Resend)
# ===========================================
# Resend API key for sending password reset emails
RESEND_API_KEY=re_your_resend_api_key_here

# Email sender address
EMAIL_FROM=OzVPS <noreply@ozvps.com.au>

# Shared secret for Resend inbound email webhook (prevents forged email injection)
# Add this as ?secret=VALUE at the end of your Resend inbound webhook URL
# Generate with: openssl rand -hex 32
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret_here

# ===========================================
# ERROR TRACKING (Sentry) - RECOMMENDED
# ===========================================
# Sentry DSN for error tracking
# Get this from your Sentry project settings
SENTRY_DSN=https://your_key@sentry.io/your_project_id

# Sentry environment tag
SENTRY_ENVIRONMENT=production

# ===========================================
# MONITORING - OPTIONAL
# ===========================================
# Log level: debug | info | warn | error
LOG_LEVEL=info
